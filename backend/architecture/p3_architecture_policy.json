{
  "schema_version": "p3.architecture.policy.v1",
  "layers": {
    "base": {
      "description": "Execution, security, evidence/contracts, source_model, platform_contracts, library_contracts",
      "families": [
        "execution",
        "security",
        "evidence_contracts",
        "source_model",
        "platform_contracts",
        "library_contracts"
      ],
      "may_depend_on": [],
      "may_not_depend_on": [
        "provider_integration",
        "transports",
        "sessions",
        "media_delivery",
        "media_probe",
        "playback_decision",
        "playback_handoff",
        "runtime_revision",
        "integration_harness",
        "architecture_guard",
        "golden_evidence",
        "closure"
      ]
    },
    "middle": {
      "description": "Provider integration, transports, sessions, media_delivery, media_probe",
      "families": [
        "provider_integration",
        "providers",
        "transports",
        "sessions",
        "media_delivery",
        "media_probe"
      ],
      "may_depend_on": ["base"],
      "may_not_depend_on": [
        "playback_decision",
        "playback_handoff",
        "runtime_revision",
        "renderer",
        "decoder",
        "audio_output",
        "ffmpeg"
      ]
    },
    "decision": {
      "description": "Playback decision, playback handoff, runtime revision",
      "families": [
        "playback_decision",
        "playback_handoff",
        "runtime_revision"
      ],
      "may_depend_on": ["base", "middle"],
      "may_not_depend_on": [
        "provider_implementation",
        "ffmpeg",
        "renderer",
        "decoder",
        "audio_output"
      ]
    },
    "test_tool": {
      "description": "Integration harness, architecture guard, golden evidence, closure",
      "families": [
        "integration_harness",
        "architecture_guard",
        "golden_evidence",
        "closure"
      ],
      "may_depend_on": ["base", "middle", "decision"],
      "may_not_depend_on": [],
      "is_runtime_dependency": false
    }
  },
  "forbidden_dependencies": [
    "playback_decision depends on provider implementation or ffmpeg",
    "provider depends on media_probe/ffmpeg or renderer/decoder/audio output",
    "session depends on renderer/decoder/audio output",
    "platform_contracts calls platform UI APIs",
    "tools are runtime dependencies"
  ],
  "dependency_linter_machine_checkable": true
}
