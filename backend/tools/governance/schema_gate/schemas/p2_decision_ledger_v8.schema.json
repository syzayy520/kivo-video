{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P2 Decision Ledger V8 Schema",
  "type": "object",
  "required": ["schema_version", "ledger_id", "task_id", "decisions", "timestamp_utc"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^p2-decision-ledger-v8$" },
    "ledger_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "domain", "decision", "reason", "status"],
        "properties": {
          "decision_id": { "type": "string" },
          "domain": { "type": "string" },
          "input": { "type": "object" },
          "decision": { "type": "string" },
          "reason": { "type": "string" },
          "status": { "type": "string" },
          "allowed_claim": { "type": "string" },
          "forbidden_claim": { "type": "string" }
        }
      }
    },
    "fallbacks": { "type": "array" },
    "blocked_reasons": { "type": "array" },
    "runtime_claims": { "type": "array" },
    "forbidden_claims": { "type": "array" },
    "evidence_links": { "type": "array" },
    "timestamp_utc": { "type": "string", "format": "date-time" }
  }
}
