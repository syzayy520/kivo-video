{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "P2 Inspector V8 Schema",
  "type": "object",
  "required": [
    "schema_version", "inspector_id", "task_id",
    "source_summary", "media_summary",
    "video_summary", "audio_summary",
    "subtitle_summary", "chapter_summary",
    "playback_summary", "runtime_summary", "environment_summary",
    "errors", "warnings", "redaction_summary",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^p2-inspector-v8$" },
    "inspector_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "source_summary": { "type": "object" },
    "media_summary": { "type": "object" },
    "video_summary": { "type": "object" },
    "audio_summary": { "type": "object" },
    "subtitle_summary": { "type": "object" },
    "chapter_summary": { "type": "object" },
    "playback_summary": { "type": "object" },
    "runtime_summary": { "type": "object" },
    "environment_summary": { "type": "object" },
    "errors": { "type": "array" },
    "warnings": { "type": "array" },
    "redaction_summary": { "type": "object" },
    "timestamp_utc": { "type": "string", "format": "date-time" }
  }
}
